{
  "expo": {
    "name": "Wevysya",
    "slug": "wevysya-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wevysya_logo_r.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/wevysya_logo_r.png",
      "color": "#FF6B35",
      "androidMode": "default",
      "androidCollapsedTitle": "Wevysya"
    },
    "android": {
      "package": "com.wevysya.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wevysya_logo_r.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wevysya.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/wevysya_logo_r.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-dev-client",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1b21598b-62b1-44b3-a5f6-af02bb39dff1"
      },
      "router": {}
    },
    "owner": "wevysya"
  }
}
